#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use AndyDefer\PhpSearch\Contracts\Engine\SearchEngineInterface;

function showHelp(): void
{
    echo <<<HELP
PHP Fuzzy Search Engine - CLI Tool

USAGE:
    # Indexation
    php-search index <source>
    
    # Recherche
    php-search <query> [limit]
    php-search <query> [limit] --source=<path>
    
    # Gestion
    php-search --stats [--source=<path>]
    php-search --list-indexes
    php-search --delete-index [--source=<path>]
    php-search --clear-cache [--source=<path>] [--query=<query>]

ARGUMENTS:
    source          Dossier ou fichier JSONL à indexer
    query           Terme de recherche
    limit           Nombre maximum de résultats (défaut: 5)

OPTIONS:
    --source=<path> Source spécifique (dossier ou fichier)
    --query=<query> Requête spécifique pour vider le cache
    --stats         Afficher les statistiques de l'index
    --list-indexes  Lister tous les index disponibles
    --delete-index  Supprimer l'index
    --clear-cache   Vider le cache

EXAMPLES:
    # Indexation
    php-search index ./docs
    php-search index ./docs/artists.jsonl
    php-search index ./docs2
    
    # Recherche (utilise le dernier index)
    php-search "Leonard" 10
    
    # Recherche dans un index spécifique
    php-search "Doctor" 5 --source=./docs2
    
    # Lister les index
    php-search --list-indexes
    
    # Supprimer un index spécifique
    php-search --delete-index --source=./docs
    
    # Vider le cache d'un index
    php-search --clear-cache --source=./docs

HELP;
}

$argc = $_SERVER['argc'] ?? 0;
$argv = $_SERVER['argv'] ?? [];

if ($argc < 2) {
    showHelp();
    exit(1);
}

$container = require __DIR__ . '/../config/container.php';

try {
    $engine = $container->get(SearchEngineInterface::class);

    if ($argv[1] === 'index') {
        if ($argc < 3) {
            showHelp();
            exit(1);
        }

        $source = $argv[2];

        if (!is_dir($source) && !is_file($source)) {
            throw new \InvalidArgumentException("Source invalide: {$source}");
        }

        echo "📂 Indexation de: {$source}\n";
        $count = $engine->index($source);
        echo "✅ Indexation terminée: {$count} éléments indexés\n";
        exit(0);
    }

    if ($argv[1] === '--list-indexes') {
        $indexes = $engine->listIndexes();

        if (empty($indexes)) {
            echo "❌ Aucun index trouvé.\n";
        } else {
            echo "📊 Index disponibles:\n";
            echo str_repeat('-', 60) . "\n";
            foreach ($indexes as $name => $info) {
                echo "• {$name}\n";
                echo "  📁 {$info['path']}\n";
                echo "  📄 Éléments: {$info['total_items']}\n";
                echo "  💾 Taille: " . round($info['size_bytes'] / 1024, 2) . " KB\n\n";
            }
        }
        exit(0);
    }

    if ($argv[1] === '--stats') {
        $source = extractOption($argv, '--source');
        $stats = $engine->getIndexStats($source);

        echo "📊 Statistiques de l'index:\n";
        echo str_repeat('-', 40) . "\n";
        echo "Source: {$stats['source']}\n";
        echo "Existe: " . ($stats['exists'] ? '✅ Oui' : '❌ Non') . "\n";
        echo "Éléments indexés: {$stats['total_items']}\n";
        echo "Chemin de l'index: {$stats['index_path']}\n";
        echo "Chemin du cache: {$stats['cache_path']}\n";
        if (isset($stats['index_size_bytes'])) {
            echo "Taille de l'index: " . round($stats['index_size_bytes'] / 1024, 2) . " KB\n";
        }
        exit(0);
    }

    if ($argv[1] === '--delete-index') {
        $source = extractOption($argv, '--source');
        $engine->deleteIndex($source);
        echo "✅ Index supprimé" . ($source ? " pour la source '{$source}'" : "") . "\n";
        exit(0);
    }

    if ($argv[1] === '--clear-cache') {
        $source = extractOption($argv, '--source');
        $query = extractOption($argv, '--query');
        $engine->clearCache($source, $query);
        echo "✅ Cache vidé" .
            ($source ? " pour la source '{$source}'" : "") .
            ($query ? " pour la requête '{$query}'" : "") . "\n";
        exit(0);
    }

    $query = $argv[1];
    $limit = $argc >= 3 ? (int)$argv[2] : 5;
    $source = extractOption($argv, '--source');

    $results = $engine->search($query, $limit, $source);

    if (empty($results)) {
        echo "No results found for '{$query}'.\n";
    } else {
        echo "Top " . count($results) . " results for '{$query}':\n";
        echo str_repeat('=', 80) . "\n";
        foreach ($results as $index => $result) {
            $isMax = ($result['percentage'] == 100) ? ' - [MAX POSSIBLE]' : '';
            echo ($index + 1) . '. ' . $result['name'] . "\n";
            echo "   Source: {$result['source']}\n";
            echo "   Score: {$result['score']} / max: {$result['max_possible']} - Relevance: {$result['percentage']}%{$isMax}\n";
        }
    }
} catch (Exception $e) {
    echo "Error: " . $e->getMessage() . "\n";
    exit(1);
}

function extractOption(array $argv, string $option): ?string
{
    foreach ($argv as $arg) {
        if (str_starts_with($arg, $option . '=')) {
            return substr($arg, strlen($option) + 1);
        }
    }
    return null;
}
