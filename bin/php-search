#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use AndyDefer\PhpSearch\Contracts\Services\FuzzySearchInterface;
use AndyDefer\PhpSearch\Contracts\Services\JsonlSearchInterface;

function showHelp(): void
{
    echo <<<HELP
PHP Fuzzy Search Engine - CLI Tool

USAGE:
    php-search <json-file> <query> [limit]
    php-search <directory> <fields> <query> [limit]  (pour recherche JSONL)

ARGUMENTS:
    json-file    Path to JSON file containing array of strings
    directory    Directory containing .jsonl files
    fields       Fields to search (separated by |, ex: "name|title")
    query        Search query string
    limit        Maximum number of results (default: 5)

EXAMPLES:
    # Recherche dans fichier JSON
    php-search data.json "Leonard"
    
    # Recherche dans dossier JSONL
    php-search ./data "name|title" "Leonard"
    
    # Recherche avec notation pointée
    php-search ./data "user.name|product.title" "John" 10

HELP;
}

$argc = $_SERVER['argc'] ?? 0;
$argv = $_SERVER['argv'] ?? [];

if ($argc < 3) {
    showHelp();
    exit(1);
}

$container = require __DIR__ . '/../config/container.php';

try {
    // Détecter si c'est une recherche JSONL ou JSON
    if (is_dir($argv[1])) {
        // Mode JSONL
        if ($argc < 4) {
            showHelp();
            exit(1);
        }

        $directory = $argv[1];
        $fields = $argv[2];
        $query = $argv[3];
        $limit = $argc >= 5 ? (int)$argv[4] : 5;

        $jsonlSearch = $container->get(JsonlSearchInterface::class);
        $results = $jsonlSearch->search($directory, $fields, $query, $limit);

        // Formatage des résultats JSONL
        if (empty($results)) {
            echo "No results found for '{$query}'.\n";
        } else {
            echo "Top " . count($results) . " results for '{$query}' in '{$directory}':\n";
            echo str_repeat('=', 80) . "\n";
            foreach ($results as $index => $result) {
                $isMax = ($result['percentage'] == 100) ? ' - [MAX POSSIBLE]' : '';
                echo ($index + 1) . '. ' . basename($result['file']) . ' (line ' . $result['line'] . ")\n";
                echo "   Data: " . json_encode($result['data']) . "\n";
                echo "   Score: {$result['score']} / max: {$result['max_possible']} - Relevance: {$result['percentage']}%{$isMax}\n";
            }
        }
    } else {
        // Mode JSON classique
        $jsonFile = $argv[1];
        $query = $argv[2];
        $limit = $argc >= 4 ? (int)$argv[3] : 5;

        $fuzzySearch = $container->get(FuzzySearchInterface::class);
        $results = $fuzzySearch->searchFromFile($jsonFile, $query, $limit);
        echo $fuzzySearch->formatResults($results, $query);
    }
} catch (Exception $e) {
    echo "Error: " . $e->getMessage() . "\n";
    exit(1);
}
