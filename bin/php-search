#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use AndyDefer\PhpSearch\Contracts\Services\IndexedSearchInterface;
use AndyDefer\PhpSearch\Contracts\Services\JsonlSearchInterface;

function showHelp(): void
{
    echo <<<HELP
PHP Fuzzy Search Engine - CLI Tool

USAGE:
    # Indexation
    php-search index <source>                    # Indexer un dossier de fichiers JSONL
    
    # Recherche directe (sans index)
    php-search <directory> <fields> <query> [limit]
    
    # Recherche indexée (rapide)
    php-search --indexed <query> [limit]

ARGUMENTS:
    source          Dossier contenant des fichiers JSONL à indexer
    directory       Dossier contenant des fichiers JSONL
    fields          Champs à rechercher (séparés par |, ex: "name|title")
    query           Terme de recherche
    limit           Nombre maximum de résultats (défaut: 5)

EXAMPLES:
    # Indexation
    php-search index ./data_folder
    
    # Recherche directe
    php-search ./data "name|title" "Leonard"
    
    # Recherche avec notation pointée
    php-search ./data "user.name|product.title" "John" 10
    
    # Recherche indexée
    php-search --indexed "Leonard" 10

HELP;
}

$argc = $_SERVER['argc'] ?? 0;
$argv = $_SERVER['argv'] ?? [];

if ($argc < 2) {
    showHelp();
    exit(1);
}

$container = require __DIR__ . '/../config/container.php';

try {
    // Mode indexation
    if ($argv[1] === 'index') {
        if ($argc < 3) {
            showHelp();
            exit(1);
        }

        $source = $argv[2];

        if (!is_dir($source)) {
            throw new \InvalidArgumentException("Source invalide: {$source} - Doit être un dossier");
        }

        $indexedSearch = $container->get(IndexedSearchInterface::class);
        $count = $indexedSearch->index($source);

        echo "✅ Indexation terminée: {$count} éléments indexés\n";
        $stats = $indexedSearch->getIndexStats();
        echo "📁 Dossier d'index: {$stats['index_path']}\n";
        exit(0);
    }

    // Mode recherche indexée
    if ($argv[1] === '--indexed') {
        if ($argc < 3) {
            showHelp();
            exit(1);
        }

        $query = $argv[2];
        $limit = $argc >= 4 ? (int)$argv[3] : 5;

        $indexedSearch = $container->get(IndexedSearchInterface::class);
        $results = $indexedSearch->search($query, $limit);

        if (empty($results)) {
            echo "No results found for '{$query}'.\n";
        } else {
            echo "Top " . count($results) . " results for '{$query}':\n";
            echo str_repeat('=', 80) . "\n";
            foreach ($results as $index => $result) {
                $isMax = ($result['percentage'] == 100) ? ' - [MAX POSSIBLE]' : '';
                echo ($index + 1) . '. ' . $result['name'] . "\n";
                echo "   Source: {$result['source']}\n";
                echo "   Score: {$result['score']} / max: {$result['max_possible']} - Relevance: {$result['percentage']}%{$isMax}\n";
            }
        }
        exit(0);
    }

    // Mode recherche directe JSONL
    if ($argc < 4) {
        showHelp();
        exit(1);
    }

    $directory = $argv[1];
    $fields = $argv[2];
    $query = $argv[3];
    $limit = $argc >= 5 ? (int)$argv[4] : 5;

    if (!is_dir($directory)) {
        throw new \InvalidArgumentException("Dossier invalide: {$directory}");
    }

    $jsonlSearch = $container->get(JsonlSearchInterface::class);
    $results = $jsonlSearch->search($directory, $fields, $query, $limit);

    if (empty($results)) {
        echo "No results found for '{$query}'.\n";
    } else {
        echo "Top " . count($results) . " results for '{$query}' in '{$directory}':\n";
        echo str_repeat('=', 80) . "\n";
        foreach ($results as $index => $result) {
            $isMax = ($result['percentage'] == 100) ? ' - [MAX POSSIBLE]' : '';
            echo ($index + 1) . '. ' . basename($result['file']) . ' (line ' . $result['line'] . ")\n";
            echo "   Data: " . json_encode($result['data']) . "\n";
            echo "   Score: {$result['score']} / max: {$result['max_possible']} - Relevance: {$result['percentage']}%{$isMax}\n";
        }
    }
} catch (Exception $e) {
    echo "Error: " . $e->getMessage() . "\n";
    exit(1);
}
